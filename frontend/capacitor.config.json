{
  "appId": "com.yanjoy.joyrecall",
  "appName": "JoyRecall",
  "webDir": "build",
  "backgroundColor": "#020617",
  "android": {
    "allowMixedContent": false
  },
  "ios": {
    "contentInset": "automatic"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Camera": {
      "androidScaleType": "FIT_CENTER"
    }
  }
}
